{
	"schemaVersion": 1,
	"id": "${id}",
	"version": "${version}",
	"name": "${name}",
	"description": "${description}",
	"authors": [
		"lowercasebtw",
		"mineland"
	],
	"contact": {
		"sources": "${source}",
		"issues": "${issues}"
	},
	"license": "${license}",
	"icon": "assets/${id}/icon.png",
	"environment": "client",
	"entrypoints": {
		"client": [
			"btw.lowercase.widgetplus.WidgetPlusClient"
		],
		"modmenu": [
			"btw.lowercase.widgetplus.config.ModMenuIntegration"
		]
	},
	"mixins": [
		"${id}.mixins.json"
	],
	"depends": {
		"fabricloader": ">=${fabric_loader_version}",
		"minecraft": "${minecraft_version_range}",
		"fabric-api": ">=${fabric_api_version}",
		"yet_another_config_lib_v3": "${yacl_version}"
	},
	"custom": {
		"modmenu": {
			"links": {
				"modmenu.discord": "${discord}",
				"modmenu.modrinth": "${modrinth}",
				"modmenu.curseforge": "${curseforge}"
			},
			"update_checker": true
		}
	}
}